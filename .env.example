# --- Database -------------------------------------------------------------
# Development default is SQLite; use PostgreSQL in production:
# DATABASE_URL=postgresql+psycopg2://erp:erp@localhost:5432/erp
DATABASE_URL=sqlite:///./tax_certificates.db

# --- Storage ---------------------------------------------------------------
STORAGE_DIR=./storage

# --- Hosted certificate links (WhatsApp document messages) ------------------
PUBLIC_BASE_URL=http://localhost:8000
LINK_SIGNING_SECRET=replace-with-a-long-random-string

# --- Offline dispatch queue --------------------------------------------------
DISPATCH_POLL_SECONDS=30
